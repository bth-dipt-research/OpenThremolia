            "content": "{\"message\":\"Continuing STRIDE-per-process threats for remaining process elements.\",\"threats\":[{\"id\":41,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Attacker spoofs Automation Account identity to submit unauthorized runbooks.\",\"element_type\":\"Process\",\"stride\":\"Spoofing\",\"Mitre ATT&CK\":\"T1078: Valid Accounts\",\"OWASP Top 10\":\"A07: Identification and Authentication Failures\",\"mitigation\":\"Limit identity assignments; require MFA for portal; audit identity usage.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H\"},{\"id\":42,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Automation Account configuration tampered to add malicious modules or connections.\",\"element_type\":\"Process\",\"stride\":\"Tampering\",\"Mitre ATT&CK\":\"T1562: Impair Defenses\",\"OWASP Top 10\":\"A05: Security Misconfiguration\",\"mitigation\":\"Lock account configuration via Azure Policy; enable resource locks.\",\"cvss_vector\":\"AV:N/AC:L/PR:H/UI:N/S:U/C:H/I:H/A:H\"},{\"id\":43,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Lack of audit trail for Automation Account actions allows repudiation.\",\"element_type\":\"Process\",\"stride\":\"Repudiation\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A09: Security Logging and Monitoring Failures\",\"mitigation\":\"Enable Automation Account auditing; send logs to Log Analytics with retention.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:L/A:N\"},{\"id\":44,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Credentials or assets in Automation Account (modules, certificates) exposed to attackers.\",\"element_type\":\"Process\",\"stride\":\"Information Disclosure\",\"Mitre ATT&CK\":\"T1537: Transfer Data to Cloud Account\",\"OWASP Top 10\":\"A02: Cryptographic Failures\",\"mitigation\":\"Use Key Vault for credentials; restrict runbook asset access; enforce HTTPS access.\",\"cvss_vector\":\"AV:N/AC:L/PR:H/UI:N/S:C/C:H/I:N/A:N\"},{\"id\":45,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Flood of runbook executions exhausts Automation Account quota causing denial of service.\",\"element_type\":\"Process\",\"stride\":\"Denial of Service\",\"Mitre ATT&CK\":\"T1499: Endpoint Denial of Service\",\"OWASP Top 10\":null,\"mitigation\":\"Implement runbook execution limits; monitor job count; use throttling policies.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":46,\"element\":\"azurerm_automation_account.dev_automation_account_test\",\"threat_description\":\"Automation Account identity abused to elevate privileges in the subscription.\",\"element_type\":\"Process\",\"stride\":\"Elevation of Privileges\",\"Mitre ATT&CK\":\"T1548: Abuse Elevation Control Mechanism\",\"OWASP Top 10\":\"A05: Security Misconfiguration\",\"mitigation\":\"Assign least-privilege role; use PIM for elevated roles; monitor RBAC changes.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H\"},{\"id\":47,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Attacker spoofs runbook identity to execute malicious scripts against Azure resources.\",\"element_type\":\"Process\",\"stride\":\"Spoofing\",\"Mitre ATT&CK\":\"T1078: Valid Accounts\",\"OWASP Top 10\":\"A07: Identification and Authentication Failures\",\"mitigation\":\"Enforce managed identity constraints; restrict runbook assignments.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H\"},{\"id\":48,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Runbook code tampered in storage before execution injecting harmful commands.\",\"element_type\":\"Process\",\"stride\":\"Tampering\",\"Mitre ATT&CK\":\"T1553: Subvert Trust Controls\",\"OWASP Top 10\":\"A08: Software and Data Integrity Failures\",\"mitigation\":\"Store runbooks in VC-backed repo; enable checksum verification; restrict storage write.\",\"cvss_vector\":\"AV:L/AC:L/PR:H/UI:N/S:C/C:H/I:H/A:H\"},{\"id\":49,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Absence of tamper-proof logs for runbook schedule and execution leads to repudiation.\",\"element_type\":\"Process\",\"stride\":\"Repudiation\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A09: Security Logging and Monitoring Failures\",\"mitigation\":\"Forward runbook logs to immutable SIEM; enable audit policies.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:L/A:N\"},{\"id\":50,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Runbook outputs include secrets or keys leaked in cleartext.\",\"element_type\":\"Process\",\"stride\":\"Information Disclosure\",\"Mitre ATT&CK\":\"T1537: Transfer Data to Cloud Account\",\"OWASP Top 10\":\"A02: Cryptographic Failures\",\"mitigation\":\"Mask sensitive outputs; use secure variables from Key Vault; scrub logs.\",\"cvss_vector\":\"AV:N/AC:L/PR:H/UI:N/S:C/C:H/I:N/A:N\"},{\"id\":51,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Long-running or looping runbook jobs exhaust quota causing DoS for other automations.\",\"element_type\":\"Process\",\"stride\":\"Denial of Service\",\"Mitre ATT&CK\":\"T1499: Endpoint Denial of Service\",\"OWASP Top 10\":null,\"mitigation\":\"Set job timeout; monitor runbook health; enforce retry policies.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":52,\"element\":\"azurerm_automation_runbook.dev_automation_runbook\",\"threat_description\":\"Runbook executes under high-privilege identity, enabling subscription-wide control abuse.\",\"element_type\":\"Process\",\"stride\":\"Elevation of Privileges\",\"Mitre ATT&CK\":\"T1068: Exploitation for Privilege Escalation\",\"OWASP Top 10\":\"A04: Insecure Design\",\"mitigation\":\"Use least-privilege identity; separate roles for different runbooks; monitor identity activity.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H\"},{\"id\":53,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Unauthorized script invocation spoofs file-populate operation against database.\",\"element_type\":\"Process\",\"stride\":\"Spoofing\",\"Mitre ATT&CK\":\"T1204: User Execution\",\"OWASP Top 10\":\"A07: Identification and Authentication Failures\",\"mitigation\":\"Validate script origin; restrict execution to CI host; code-sign scripts.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:N\"},{\"id\":54,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Local create-table.py script tampered to execute arbitrary DB commands.\",\"element_type\":\"Process\",\"stride\":\"Tampering\",\"Mitre ATT&CK\":\"T1059: Command and Scripting Interpreter\",\"OWASP Top 10\":\"A08: Software and Data Integrity Failures\",\"mitigation\":\"Store scripts in VCS; verify checksums; restrict local modifications.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:C/C:H/I:H/A:H\"},{\"id\":55,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Lack of logging on data population scripts allows developer to repudiate changes.\",\"element_type\":\"Process\",\"stride\":\"Repudiation\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A09: Security Logging and Monitoring Failures\",\"mitigation\":\"Log script actions to central store; include timestamps and user IDs.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:L/A:N\"},{\"id\":56,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Script outputs CosmosDB key in logs, leaking credentials.\",\"element_type\":\"Process\",\"stride\":\"Information Disclosure\",\"Mitre ATT&CK\":\"T1537: Transfer Data to Cloud Account\",\"OWASP Top 10\":\"A02: Cryptographic Failures\",\"mitigation\":\"Mask sensitive parameters; use environment variables securely; no plaintext logs.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:C/C:H/I:N/A:N\"},{\"id\":57,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Script floods CosmosDB with repeated calls causing throughput exhaustion.\",\"element_type\":\"Process\",\"stride\":\"Denial of Service\",\"Mitre ATT&CK\":\"T1499: Endpoint Denial of Service\",\"OWASP Top 10\":null,\"mitigation\":\"Add rate-limiting; use SDK retries; monitor RU consumption.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:R/S:U/C:N/I:N/A:H\"},{\"id\":58,\"element\":\"null_resource.file_populate_data\",\"threat_description\":\"Script runs with admin credentials, enabling privilege escalation to subscription.\",\"element_type\":\"Process\",\"stride\":\"Elevation of Privileges\",\"Mitre ATT&CK\":\"T1548: Abuse Elevation Control Mechanism\",\"OWASP Top 10\":\"A04: Insecure Design\",\"mitigation\":\"Use least-privilege service principal; limit script credentials scope.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:C/C:H/I:H/A:H\"},{\"id\":59,\"element\":\"null_resource.env_replace\",\"threat_description\":\"Spoofed env_replace script injects malicious environment variables into code.\",\"element_type\":\"Process\",\"stride\":\"Spoofing\",\"Mitre ATT&CK\":\"T1556: Modify Authentication Process\",\"OWASP Top 10\":\"A07: Identification and Authentication Failures\",\"mitigation\":\"Lock script files; verify integrity; store in secured repo.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:N\"},{\"id\":60,\"element\":\"null_resource.env_replace\",\"threat_description\":\"Configuration patcher tampered to insert wrong connection strings or keys.\",\"element_type\":\"Process\",\"stride\":\"Tampering\",\"Mitre ATT&CK\":\"T1553: Subvert Trust Controls\",\"OWASP Top 10\":\"A08: Software and Data Integrity Failures\",\"mitigation\":\"Use signed config templates; validate JSON schema.\",\"cvss_vector\":\"AV:L/AC:L/PR:N/UI:R/S:C/C:H/I:H/A:H\"},{\"id\":61,\"element\":\"null_resource.env_replace\",\"threat_description\":\"Lack of trace for env_replace executio