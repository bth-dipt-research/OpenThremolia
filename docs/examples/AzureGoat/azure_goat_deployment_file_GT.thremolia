\":\"Data Store\",\"stride\":\"Denial of Service\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":null,\"mitigation\":\"Apply NSG throttling; monitor flow logs; segment high-volume services.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":155,\"element\":\"azurerm_public_ip.VM_PublicIP\",\"threat_description\":\"Public IP DNS label tampered to redirect traffic to rogue endpoint.\",\"element_type\":\"Data Store\",\"stride\":\"Tampering\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A05: Security Misconfiguration\",\"mitigation\":\"Lock Public IP resource; audit DNS label changes; use Azure Policy.\",\"cvss_vector\":\"AV:N/AC:L/PR:H/UI:N/S:C/C:H/I:H/A:N\"},{\"id\":156,\"element\":\"azurerm_public_ip.VM_PublicIP\",\"threat_description\":\"No logs for Public IP assignment changes allows repudiation.\",\"element_type\":\"Data Store\",\"stride\":\"Repudiation\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A09: Security Logging and Monitoring Failures\",\"mitigation\":\"Enable Activity Logs for Public IP; forward to SIEM.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:L/A:N\"},{\"id\":157,\"element\":\"azurerm_public_ip.VM_PublicIP\",\"threat_description\":\"Public IP exposed reveals live endpoints to attackers.\",\"element_type\":\"Data Store\",\"stride\":\"Information Disclosure\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":\"A02: Cryptographic Failures\",\"mitigation\":\"Use Azure Firewall or NAT gateway; restrict NSG egress; hide IP via proxy.\",\"cvss_vector\":\"AV:N/AC:H/PR:N/UI:N/S:U/C:L/I:N/A:N\"},{\"id\":158,\"element\":\"azurerm_public_ip.VM_PublicIP\",\"threat_description\":\"High-volume traffic to Public IP saturates bandwidth causing DoS.\",\"element_type\":\"Data Store\",\"stride\":\"Denial of Service\",\"Mitre ATT&CK\":null,\"OWASP Top 10\":null,\"mitigation\":\"Use DDoS Protection Standard; rate limit at firewall.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":159,\"element\":\"azurerm_network_interface.net_int\",\"threat_description\":