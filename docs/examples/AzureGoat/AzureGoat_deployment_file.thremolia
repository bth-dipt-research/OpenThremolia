C:H/I:H/A:N\"},{\"id\":197,\"element\":\"function_app \u2192 Storage Account\",\"threat_description\":\"Storage access keys leaked over network expose all blobs.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use managed identities, avoid embedding connection strings, rotate keys regularly.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":198,\"element\":\"function_app \u2192 Storage Account\",\"threat_description\":\"High volume of blob reads/writes saturates storage throughput.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Implement client-side throttling, use CDNs for static assets.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":199,\"element\":\"null_resource.file_replacement_upload \u2192 Shared storage containers\",\"threat_description\":\"Uploaded patch operations are tampered to inject malicious asset URLs.\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Verify patch scripts and manifests via signatures before upload.\",\"cvss_vector\":\"AV:L/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":200,\"element\":\"null_resource.file_replacement_upload \u2192 Shared storage containers\",\"threat_description\":\"Patch upload outputs leaked in logs reveal internal container URLs.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Mask URLs in logs, use secure environment variables for endpoint references.\",\"cvss_vector\":\"AV:L/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":201,\"element\":\"null_resource.file_replacement_upload \u2192 Shared storage containers\",\"threat_description\":\"Patch script errors flood storage account, causing slowdowns.\",\"element_type\":\"Data Flow\",\"stride\":