iption\":\"Client metadata or tokens leaked in requests expose session data.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use secure cookies, enforce same-site policies, and redact sensitive headers.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":207,\"element\":\"Clients \u2192 function_app_front\",\"threat_description\":\"Flood of HTTP requests to front-end causes service throttle or crash.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Implement WAF, rate limiting, and autoscaling for function app front.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":208,\"element\":\"Clients \u2192 function_app\",\"threat_description\":\"API requests are tampered to bypass authentication or inject SQL/NoSQL commands.\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Validate and sanitize inputs, enforce token validation, and use parameterized queries.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":209,\"element\":\"Clients \u2192 function_app\",\"threat_description\":\"API request parameters leaked expose application logic or sensitive data paths.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Avoid verbose error messages, use generic error codes, and log only non-sensitive data.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":210,\"element\":\"Clients \u2192 function_app\",\"threat_description\":\"High volume of API calls overloads function app, causing timeouts.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Set request quotas, enable rate limiting in API Management, and use circuit breakers.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":211,\"element\":\"function_app_front \u2192 Storage Account\",\"threat_description\":\"Front-end asset fetches are tampered to load malicious blobs.\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Enforce HTTPS, validate asset integrity with SRI, and use signed URLs.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":212,\"element\":\"function_app_front \u2192 Storage Account\",\"threat_description\":\"Credentials or SAS tokens in fetch requests are exposed to network sniffers.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use managed identity for blob access and remove secrets from client code.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":213,\"element\":\"function_app_front \u2192 Storage Account\",\"threat_description\":\"Excessive blob fetch requests from front-end degrade storage performance.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use caching at CDN, implement client-side throttling, and monitor request rates.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":214,\"element\":\"azurerm_virtual_machine_extension.test \u2192 VM\",\"threat_description\":\"Extension payload is tampered in transit, leading to execution of malicious scripts on VM.\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use signed extension packages, enforce TLS, and validate checksums before execution.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":215,\"element\":\"azurerm_virtual_machine_extension.test \u2192 VM\",\"threat_description\":\"Extension logs leak sensitive configuration or credentials to VM console.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Redact secrets in extensions logs and send to secure log aggregator.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":216,\"element\":\"azurerm_virtual_machine_extension.test \u2192 VM\",\"threat_description\":\"Malicious or malformed extension payload crashes VM provisioning.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Implement validation and timeouts for VM extension runs.\",\"cvss_vector\":\"AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":217,\"element\":\"VM \u2192 azurerm_storage_blob.app_files_vm\",\"threat_description\":\"VM retrieval requests are tampered to fetch malicious scripts from storage.\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Use managed identity for blob access and enforce HTTPS with TLS.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":218,\"element\":\"VM \u2192 azurerm_storage_blob.app_files_vm\",\"threat_description\":\"Script fetch responses leak storage URLs or credentials to VM logs.\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Disable verbose logging, rotate SAS tokens, and use private endpoints.\",\"cvss_vector\":\"AV:N/AC:L/PR:L/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":219,\"element\":\"VM \u2192 azurerm_storage_blob.app_files_vm\",\"threat_description\":\"High-frequency script fetches slow storage endpoints, delaying VM setup.\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\": null,\"owasp_top_10_for_llm\": null,\"mitigation\":\"Cache scripts locally and monitor storage request metrics for anomalies.\",\"cvss_vector\":\"AV:N/AC:L/PR: