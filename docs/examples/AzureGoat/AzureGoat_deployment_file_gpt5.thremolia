        {
            "id": 15,
            "element": "azurerm_storage_account.storage_account",
            "threat_description": "Attackers with leaked keys/connection string/SAS can modify or upload blobs (code/packages).",
            "element_type": "Data Store",
            "stride": "Tampering",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Disable account key access (use Azure AD RBAC), rotate keys, scope SAS to read-only and shortest TTL, enable versioning/immutability and soft delete.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:H/VI:H/VA:M/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 16,
            "element": "azurerm_storage_account.storage_account",
            "threat_description": "Insufficient logging leads to inability to attribute blob/container changes made via SAS tokens.",
            "element_type": "Data Store",
            "stride": "Repudiation",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Enable Storage Analytics/Diagnostic logs to Log Analytics, include SAS identifier (signedIdentifier), and retain logs with immutability.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:M/VI:M/VA:N/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 17,
            "element": "azurerm_storage_account.storage_account",
            "threat_description": "Public endpoints with permissive CORS and anonymous containers expose data and metadata.",
            "element_type": "Data Store",
            "stride": "Information Disclosure",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Disable public access, restrict CORS to known origins/methods, use Private Endpoints and firewall, and serve public content via CDN/Front Door with WAF.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:H/VI:N/VA:N/SC:N/SI:N/SA:N",
            "cvss_score": 8.7,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 18,
            "element": "azurerm_storage_account.storage_account",
            "threat_description": "Unbounded anonymous reads and expensive operations (e.g., range requests) can incur cost spikes or throttle the service.",
            "element_type": "Data Store",
            "stride": "Denial of Service",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Use CDN caching, rate limiting at edge, private access, set Azure Monitor alerts on egress/transactions, and automatic scaling policies.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:N/VI:N/VA:H/SC:N/SI:N/SA:N",
            "cvss_score": 8.7,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 19,
            "element": "azurerm_storage_container.storage_container (blob-level public)",
            "threat_description": "SAS token with write permissions allows code/package tampering within the container.",
            "element_type": "Data Store",
            "stride": "Tampering",
            "mitre_atlas": null,
