        {
            "id": 14,
            "element": "Azure Resource Manager / Control Plane",
            "threat_description": "Excessive privileges at RG scope (Owner/Contributor) enable elevation across services and lateral movement.",
            "element_type": "Process",
            "stride": "Elevation of Privileges",
            "mitre_atlas": null,
