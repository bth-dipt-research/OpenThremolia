    "valid_threats": [
        {
            "id": 1,
            "element": "Terraform Operator Workstation",
            "threat_description": "An attacker could spoof the operator workstation identity or tooling to run terraform apply with the same credentials, pushing malicious changes.",
            "element_type": "External Entity",
            "stride": "Spoofing",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Use strong MFA for provider auth, hardware-backed credentials, restrict where applies can run, IP allow-list, and sign Terraform plans/state changes (remote backend with RBAC).",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:L/UI:N/VC:H/VI:H/VA:H/SC:N/SI:N/SA:N",
            "cvss_score": 8.7,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 2,
            "element": "Terraform Operator Workstation",
            "threat_description": "Operator could repudiate destructive actions (no traceability for local-exec and manual secret handling).",
            "element_type": "External Entity",
            "stride": "Repudiation",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Use remote state with audit logs, enable Azure Activity Logs/Defender, log local-exec output to append-only storage, code review and signed commits, require change approvals.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:L/UI:N/VC:M/VI:M/VA:M/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 3,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "Malicious inputs or environment spoofing could cause Terraform/provisioners to execute under attacker-provided credentials or endpoints.",
            "element_type": "Process",
            "stride": "Spoofing",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Pin providers with checksums, lock provider versions, validate backend/tenant IDs, use explicit subscription/tenant in providers, and scoped service principals with least privilege.",
            "cvss_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:H/VI:H/VA:H/SC:N/SI:N/SA:N",
            "cvss_score": 8.5,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 4,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "sed/Python steps can be tampered to inject backdoors or alter code packages before upload.",
            "element_type": "Process",
            "stride": "Tampering",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Use immutable build pipeline, signed artifacts, verify hashes before upload, ensure local scripts are from version-controlled sources, enable Defender for DevOps controls.",
            "cvss_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:H/VI:H/VA:M/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 5,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "Lack of auditing for local-exec steps enables denial or dispute of secret use and file modifications.",
            "element_type": "Process",
            "stride": "Repudiation",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Redirect stdout/stderr to append-only logs, store in secure logging service, maintain change management with approvals and signed plan/apply.",
            "cvss_vector": "CVSS:4.0/AV:N/AC:L/AT:N/PR:L/UI:N/VC:M/VI:M/VA:N/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 6,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "Secrets (Cosmos key, storage connection string, SAS, JWT) handled in plaintext files risk leakage to disk, archives, or logs.",
            "element_type": "Process",
            "stride": "Information Disclosure",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Use Key Vault references and Managed Identity, avoid writing secrets to local.settings.json, scrub logs, use environment variables or ephemeral secret mounts, and encrypt local disks.",
            "cvss_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:H/VI:N/VA:N/SC:N/SI:N/SA:N",
            "cvss_score": 6.8,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 7,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "Long-running or recursive local tasks can hang pipeline or exhaust local resources, delaying or blocking deployment.",
            "element_type": "Process",
            "stride": "Denial of Service",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Set explicit timeouts, resource limits, and retries; isolate heavy tasks into CI runners; use remote build stages.",
            "cvss_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:N/VI:N/VA:M/SC:N/SI:N/SA:N",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
            "id": 8,
            "element": "Terraform CLI and Provisioners",
            "threat_description": "Executing arbitrary scripts with provider credentials can lead to privilege escalation across Azure resources.",
            "element_type": "Process",
            "stride": "Elevation of Privileges",
            "mitre_atlas": null,
            "owasp_top_10_for_llm": null,
            "mitigation": "Run with least-privileged service principal, split applies by scope, enforce policy as code (Azure Policy/OPA), and restrict local-exec to whitelisted scripts.",
            "cvss_vector": "CVSS:4.0/AV:L/AC:L/AT:N/PR:L/UI:N/VC:H/VI:H/VA:M/SC:C/SI:M/SA:M",
            "cvss_score": NaN,
            "threat_source": "llm",
            "validation": true,
            "justification": null,
            "mitigated": false
        },
        {
