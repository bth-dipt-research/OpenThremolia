os DB\",\"threat_description\":\"High volume of queries or large data loads causes DB throttling\",\"element_type\":\"Data Store\",\"stride\":\"Denial of Service\",\"mitre_atlas\":null,\"owasp_top_10_for_llm\":null,\"mitigation\":\"Set request units quotas; monitor and autoscale throughput.\",\"cvss_vector\":\"CVSS:4.0/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":61,\"element\":\"User \u2192 Blog Application\",\"threat_description\":\"Attacker tampers with HTTP requests in transit\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\":null,\"owasp_top_10_for_llm\":null,\"mitigation\":\"Enforce HTTPS/TLS with HSTS.\",\"cvss_vector\":\"CVSS:4.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":62,\"element\":\"User \u2192 Blog Application\",\"threat_description\":\"Eavesdropping on user requests leaks session tokens or PII\",\"element_type\":\"Data Flow\",\"stride\":\"Information Disclosure\",\"mitre_atlas\":null,\"owasp_top_10_for_llm\":null,\"mitigation\":\"Use end-to-end encryption (TLS 1.2+).\",\"cvss_vector\":\"CVSS:4.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N\"},{\"id\":63,\"element\":\"User \u2192 Blog Application\",\"threat_description\":\"Flood of HTTP requests overwhelms the front-end\",\"element_type\":\"Data Flow\",\"stride\":\"Denial of Service\",\"mitre_atlas\":null,\"owasp_top_10_for_llm\":null,\"mitigation\":\"Deploy WAF and rate limiting at edge.\",\"cvss_vector\":\"CVSS:4.0/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:H\"},{\"id\":64,\"element\":\"Blog Application \u2192 Application Resource Storage Container\",\"threat_description\":\"Modification of blobs mid-transfer\",\"element_type\":\"Data Flow\",\"stride\":\"Tampering\",\"mitre_atlas\":null,\"owasp_top_10_for_llm\":null,\"mitigation\":\"Use HTTPS and validate blob checksums.\",\"cvss_vector\":\"CVSS:4.0/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N\"},{\"id\":65,\"element\":\"Blog Application \u2192 Application Resource Storage Container\",\"threat_description\":\"Interception of sensitive config duri